{
  "name": "@siftingio/sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for the SiftingIO market data API (REST + WebSocket).",
  "license": "MIT",
  "author": "SiftingIO",
  "homepage": "https://sifting.io/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/siftingio/sdk-typescript.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run build",
    "prepublishOnly": "npm run build"
  },
  "optionalDependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "siftingio",
    "sifting",
    "market-data",
    "stocks",
    "crypto",
    "forex",
    "sec",
    "edgar",
    "fundamentals",
    "xbrl",
    "websocket",
    "api",
    "sdk"
  ]
}
